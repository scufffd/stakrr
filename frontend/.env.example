# Stakrr frontend env. Copy to `.env` and fill in.

# Solana RPC the wallet/Anchor client talks to. Default `mainnet-beta` is
# rate-limited so the staking client will silently fail to load on first
# fetch — point this at Helius (or any private RPC) for it to work.
VITE_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Optional WalletConnect (QR / mobile). Create a project at https://cloud.reown.com
# and set the ID here so "WalletConnect" appears in the wallet modal.
# VITE_WALLETCONNECT_PROJECT_ID=

# Worker API: if you see "Unexpected token '<'" on /api/..., the app got HTML (usually
# Vite's index page) instead of JSON — start the worker (`cd worker && npm run serve`)
# or set VITE_API_URL to bypass the dev proxy:
# VITE_API_URL=http://127.0.0.1:3060
# Vite dev/preview proxy target (must match worker PORT):
# VITE_PROXY_TARGET=http://127.0.0.1:3060

# Optional override of the on-chain pob-index-stake program ID. Defaults to
# the canonical one (65YrGaBL5ukm4SVcsEBoUgnqTrNXy2pDiPKeQKjSexVA).
# VITE_STAKE_PROGRAM_ID=

# Footer / docs “View on GitHub” link (your repo or profile).
# VITE_GITHUB_URL=https://github.com/your-org/stakrr
