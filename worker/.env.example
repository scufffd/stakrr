# --- RPC ---
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
STAKE_RPC_URL=
# Comma-separated public RPCs the worker will fall back to on 429/401/403/5xx
# from the primary. Every endpoint must speak generic Solana JSON-RPC — we
# never call Helius Enhanced API. Leave blank to disable fallback (not
# recommended for production).
RPC_URL_FALLBACKS=https://api.mainnet-beta.solana.com,https://solana-rpc.publicnode.com,https://solana.drpc.org

# --- On-chain program ---
STAKE_PROGRAM_ID=65YrGaBL5ukm4SVcsEBoUgnqTrNXy2pDiPKeQKjSexVA
WSOL_MINT=So11111111111111111111111111111111111111112

# --- Wallets ---
# Treasury: used for legacy treasury-funded pools only. New launches are creator-funded:
# the connected wallet pays Pump create + pool init + reward registration; it is the pool
# authority and Pump fee recipient. The worker still uses treasury for those pools' cycles.
PLATFORM_TREASURY_PRIVATE_KEY=
# Authority: signs claim_push / deposit for pools where the platform is pool authority
# (treasury-launched). Creator-launched pools (`launchFunding: 'creator'`) skip automated cycles.
PLATFORM_AUTHORITY_PRIVATE_KEY=

# --- Pump.fun integration (https://pumpdev.io/) ---
PUMPDEV_API_BASE=https://pumpdev.io
PUMPDEV_API_KEY=
# Optional: JSON merged into PumpDev POST /api/create. The worker also calls
# POST /api/claim-distribute before each claim cycle when a mint is known
# (see https://pumpdev.io/claim-distribute).
PUMPDEV_CREATE_EXTRA_JSON=

# --- Pump fee-share lock (pump_fees program: pfeeUxB6jkeY1Hxd7CsFCAjcbHA9rWtchMGdZ6VojVZ) ---
# When enabled, every Stakrr launch runs an extra tx after the Pump create
# that calls `create_fee_sharing_config` + `update_fee_shares`. This migrates
# the on-chain BondingCurve.creator from the deployer wallet to a
# FeeSharingConfig PDA, and routes 100% of creator royalties to the recipient
# below. Verifiable on Solscan; deployer cannot redirect once locked because
# the pool authority on Pump is now a program-owned PDA.
LOCK_FEES_ENABLED=true
# Optional override — defaults to PLATFORM_TREASURY_PRIVATE_KEY's pubkey.
LOCK_FEES_RECIPIENT=

# --- Platform economics ---
PLATFORM_FEE_BPS=200            # 2% of claimed creator fees
LAUNCH_FEE_LAMPORTS=0           # MVP: free launches
MIN_DISTRIBUTE_LAMPORTS=2000000 # Skip pools with <0.002 SOL claimable per cycle

# --- Worker loop ---
LOOP_INTERVAL_MS=600000         # 10 minutes between cycles
PRIORITY_FEE_MICROLAMPORTS=10000

# --- Server ---
LISTEN_HOST=0.0.0.0
PORT=3060

# --- Registry ---
POOL_REGISTRY_FILE=./data/pools.json
EVENT_LEDGER_FILE=./data/events.jsonl

# --- RPC tuning (mirrored from POBINDEX) ---
POB_RPC_ACCOUNT_CACHE_TTL_MS=21600000

# --- IPFS metadata upload (launch) ---
# The app tries pump.fun /api/ipfs from the *browser* first (often works without
# Pinata on home networks). The worker falls back to Pinata, then pump from its
# own IP — datacenter/VPN pump IPs often get HTTP 403; set PINATA_JWT for that path.
# Create: https://app.pinata.cloud/developers/api-keys → New Key → JWT
PINATA_JWT=
# Optional: gateway for URIs we build after Pinata pin (default = Pinata public gateway).
# IPFS_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs

# --- Optional vanity mints (PumpDev `mintKeypair` on /api/create) ---
# JSON array: [{ "publicKey": "...", "secretKey": "<base64 secret>" }, ...]
# Pre-ground keypairs used as the new token's mint address. The first UNUSED
# entry whose pubkey ends with VANITY_MINT_SUFFIX is popped per launch (used
# entries are detected on-chain and pruned). Run `npm run prune-vanity` once
# after dropping in a new pool to remove already-claimed mints.
VANITY_MINT_POOL_FILE=./data/vanity-pump.json
VANITY_MINT_SUFFIX=pump

# --- Public site (Stakrr's user-facing URL origin) ---
# When the deployer leaves their token's `website` field blank we substitute
# https://<this>/token/<mint> so every launch has a real landing page in
# Pump.fun's metadata. Override per environment (e.g. localhost dev).
PUBLIC_BASE_URL=https://stakrr.xyz
